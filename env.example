# Variables de entorno para RoomyAPI

# Puerto del servidor
PORT=5000
HOST=0.0.0.0

# IP de tu VPS (cambiar por la IP real)
VPS_IP=64.176.11.170

# Base de datos MongoDB
MONGO_URI=mongodb://mongo:27017/roomydb

# Autenticación JWT
JWT_SECRET=tu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=24h

# Sesión
SESSION_SECRET=tu_session_secret_super_seguro_aqui

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# URLs y configuración (usar IP del VPS)
CLIENT_URL=http://64.176.11.170:3000
API_URL=http://64.176.11.170:5000

# Entorno
NODE_ENV=production 